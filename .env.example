# Trinity — Environment Variables
# Copy this file to .env and fill in your keys.
# .env is never committed to GitHub.

# --- Required ---
ANTHROPIC_API_KEY=        # console.anthropic.com → API Keys
SUPABASE_URL=             # supabase.com → Project Settings → API → Project URL
SUPABASE_KEY=             # supabase.com → Project Settings → API → anon public key

# --- Eyes (optional — scraping still runs without these, just skips that source) ---
NEWS_API_KEY=             # newsapi.org → free tier, 100 req/day

# --- Discord (optional — skip if not using Discord interface) ---
DISCORD_BOT_TOKEN=        # discord.com/developers → your app → Bot → Token
DISCORD_OWNER_ID=         # your Discord user ID (Settings → Advanced → Developer Mode → right-click username)
DISCORD_AUTONOMOUS_INTERVAL=30  # how often Trinity acts on her own, in minutes (default 30)
TRINITY_LOG_CHANNEL_ID=   # Discord channel ID for Trinity's private log (optional)

# --- Monitoring defaults (edit freely) ---
REDDIT_SUBREDDITS=pkmntcg,PokemonTCG,pokemoncardcollectors,UnionArena,CryptoMoonShots,SatoshiStreetBets,solana,stocks,investing,wallstreetbets
KEYWORDS=pokemon,union arena,star card,troll,wish,MOS,mosaic,fertilizer,potash,reprint,print run,memecoin,solana
