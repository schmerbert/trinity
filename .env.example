# Trinity — Environment Variables
# Copy this file to .env and fill in your keys.
# .env is never committed to GitHub.

# --- Required ---
ANTHROPIC_API_KEY=        # console.anthropic.com → API Keys
SUPABASE_URL=             # supabase.com → Project Settings → API → Project URL
SUPABASE_KEY=             # supabase.com → Project Settings → API → anon public key

# --- Eyes (optional — scraping still runs without these, just skips that source) ---
NEWS_API_KEY=             # newsapi.org → free tier, 100 req/day

# --- TTS (optional) ---
TRINITY_TTS_VOICE=af_bella   # Kokoro voice (af_bella, af_sarah, af_sky, bf_emma, am_adam, bm_george)

# --- Runner (optional — set to true when running runner.py as standalone process) ---
TRINITY_RUNNER=false          # true = runner.py owns background cycles; widget background timers are disabled
                              # false (default) = widget owns cycles; do not run runner.py simultaneously

# --- Discord (optional — skip if not using Discord interface) ---
DISCORD_BOT_TOKEN=        # discord.com/developers → your app → Bot → Token
DISCORD_OWNER_ID=         # your Discord user ID (Settings → Advanced → Developer Mode → right-click username)
DISCORD_AUTONOMOUS_INTERVAL=60  # how often Trinity acts on her own, in minutes (default 60)
TRINITY_LOG_CHANNEL_ID=    # Discord channel ID for Trinity's private log (optional)
TRINITY_THOUGHT_CHANNEL_ID=  # Discord channel ID where widget <thought> tags are routed (optional)
TRINITY_FEED_CHANNEL_ID=   # Discord channel ID for RSS headline feed (optional — headlines post every 5 min when set)
DISCORD_HOME_GUILD_ID=     # your Discord server ID — right-click server → Copy Server ID (Developer Mode must be on)

# --- Wallet (optional — required for wallet tools) ---
TRINITY_WALLET_ADDRESS=       # Trinity's Solana wallet address (public key only — no private key for Phase 1)
SOLANA_RPC_URL=               # Custom RPC endpoint (optional — defaults to public mainnet: https://api.mainnet-beta.solana.com)

# --- Email outbound (optional — required for send_email tool) ---
TRINITY_USER_EMAIL=           # email address Trinity sends to (the user's address)
SMTP_HOST=smtp.gmail.com      # Gmail SMTP host
SMTP_PORT=587                 # 587 for STARTTLS (recommended)
SMTP_USER=                    # Gmail address used to send (can be same as TRINITY_USER_EMAIL)
SMTP_PASS=                    # Gmail App Password — myaccount.google.com/apppasswords (requires 2FA)

# --- Substack (optional — required for post_to_substack tool) ---
SUBSTACK_EMAIL=              # Substack account email
SUBSTACK_PASSWORD=           # Substack account password
SUBSTACK_PUBLICATION_URL=    # e.g. https://yourname.substack.com

# --- Reddit (optional — required for post_to_reddit tool) ---
REDDIT_CLIENT_ID=        # reddit.com/prefs/apps → create app → client_id (under app name)
REDDIT_CLIENT_SECRET=    # reddit.com/prefs/apps → secret
REDDIT_USERNAME=         # Reddit account username (the account that will post)
REDDIT_PASSWORD=         # Reddit account password
REDDIT_USER_AGENT=Trinity/1.0   # identifies the bot to Reddit API (can leave as-is)

# --- Monitoring defaults (edit freely) ---
REDDIT_SUBREDDITS=pkmntcg,PokemonTCG,pokemoncardcollectors,UnionArena,CryptoMoonShots,SatoshiStreetBets,solana,stocks,investing,wallstreetbets
KEYWORDS=pokemon,union arena,star card,troll,wish,MOS,mosaic,fertilizer,potash,reprint,print run,memecoin,solana
